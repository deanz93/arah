rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isValidReportType() {
      return request.resource.data.type in [
        'police', 'accident', 'flood', 'pothole', 'roadblock', 'hazard'
      ];
    }

    function isValidCoordinates() {
      let lat = request.resource.data.lat;
      let lng = request.resource.data.lng;
      return lat is number && lng is number
        && lat >= 1.0 && lat <= 7.5
        && lng >= 99.5 && lng <= 119.5;
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['uid', 'created_at', 'report_count']);
      allow delete: if isAdmin();
    }

    // ── Reports ───────────────────────────────────────────────────
    match /reports/{reportId} {
      // Any signed-in user can read active reports
      allow read: if isSignedIn() && resource.data.active == true;
      // Admins can read all reports
      allow read: if isAdmin();

      // Authenticated users can submit a report (rate limiting via API Gateway)
      allow create: if isSignedIn()
        && isValidReportType()
        && isValidCoordinates()
        && request.resource.data.upvotes == 0
        && request.resource.data.downvotes == 0
        && request.resource.data.active == true;

      // Any signed-in user can vote (increment upvotes/downvotes only)
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['upvotes', 'downvotes', 'active'])
        && request.resource.data.upvotes >= resource.data.upvotes
        && request.resource.data.downvotes >= resource.data.downvotes;

      // Only admins can delete reports
      allow delete: if isAdmin();
    }
  }
}
